{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python@v22"
             "config": {
                "pythonVersion": "3.9"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}
